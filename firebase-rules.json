{
  "rules": {
    "session": {
      ".read": true,
      ".write": false
    },
    "milestones": {
      "$date": {
        "$milestone": {
          ".read": true,
          ".write": "!data.exists() || data.child('name').val() === '익명'",
          ".validate": "newData.hasChildren(['name', 'date'])",
          "name": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 15"
          },
          "date": {
            ".validate": "newData.isString()"
          },
          "hiddenNum": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 10000"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },
    "countries": {
      "$date": {
        ".read": true,
        ".write": false
      }
    }
  }
}
